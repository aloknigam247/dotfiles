{
  "autoMemoryEnabled": false,
  "defaultShell": "powershell",
  "effortLevel": "high",
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY": "20",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_INSTALLATION_CHECKS": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "forceLoginMethod": "console",
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "$input | ConvertFrom-Json | ForEach-Object { & 'C:\\Program Files\\Git\\usr\\bin\\unix2dos.exe' $_.tool_input.file_path }",
            "shell": "powershell",
            "statusMessage": "Fixing line endings...",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ]
  },
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "mcp__native_tools__calculator",
      "PowerShell",
      "WebFetch"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "pwsh -NoProfile -File C:/Users/aloknigam/.claude/statusline-command.ps1",
    "type": "command"
  },
  "theme": "auto"
}