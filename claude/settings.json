{
  "env": {
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY": "20",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_INSTALLATION_CHECKS": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "mcp__native_tools__calculator",
      "WebFetch"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$d = $input | Out-String | ConvertFrom-Json; $f = if ($d.tool_input.file_path) { $d.tool_input.file_path } else { $d.tool_response.filePath }; if ($f -and (Test-Path $f) -and $f -notmatch '\\.sh$') { unix2dos $f 2>$null }",
            "shell": "powershell",
            "timeout": 5,
            "statusMessage": "Fixing line endings..."
          }
        ]
      }
    ]
  },
  "defaultShell": "powershell",
  "statusLine": {
    "type": "command",
    "command": "pwsh -NoProfile -File C:/Users/aloknigam/.claude/statusline-command.ps1"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true
}
